<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset 5D - Sinta a leveza em 5 dias | Dra. Carolina Xavier</title>
    <meta name="description" content="Protocolo médico intensivo de 5 dias para eliminar inchaço e recuperar a disposição. Criado pela Dra. Carolina Xavier.">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <style>
        /* ========== RESET & BASE ========== */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --bege-claro: #F5EDE4;
            --bege-escuro: #E5D9CC;
            --azul-principal: #162E52;
            --azul-claro: #254A70;
            --branco: #FFFFFF;
            --texto: #162E52;
            --texto-claro: #4a5568;
            --dourado: #C5A059;
            --verde-cta: #25D366;
            --fonte-titulo: 'Playfair Display', Georgia, serif;
            --fonte-corpo: 'Poppins', 'Inter', sans-serif;
        }
        
        body {
            font-family: var(--fonte-corpo);
            color: var(--texto);
            background: var(--bege-claro);
            line-height: 1.6;
        }
        
        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        .section {
            padding: 60px 0;
        }
        
        h1, h2, h3 {
            font-family: var(--fonte-titulo);
            font-weight: 700;
            line-height: 1.2;
        }
        
        .text-center { text-align: center; }
        
        /* ========== HEADER ========== */
        .header {
            background: var(--bege-escuro);
            padding: 15px 0;
            border-bottom: 1px solid rgba(197, 160, 89, 0.2);
            text-align: center;
        }
        
        .header__name {
            font-family: var(--fonte-titulo);
            font-size: 22px;
            font-weight: 700;
            color: var(--azul-principal);
        }
        
        /* ========== HERO ========== */
        .hero {
            padding: 60px 0;
            text-align: center;
            background: var(--bege-claro);
        }
        
        .hero__badge {
            display: inline-block;
            background: rgba(22, 46, 82, 0.1);
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 14px;
            color: var(--azul-principal);
            margin-bottom: 20px;
        }
        
        .hero__title {
            font-size: 42px;
            color: var(--azul-principal);
            margin-bottom: 20px;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .hero__subtitle {
            font-size: 18px;
            color: var(--texto-claro);
            margin-bottom: 30px;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .btn {
            display: inline-block;
            padding: 20px 40px;
            font-size: 18px;
            font-weight: 600;
            text-decoration: none;
            border-radius: 50px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .btn--whatsapp {
            background: var(--verde-cta);
            color: var(--branco);
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
        }
        
        .btn--whatsapp:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
        }
        
        .trust-bar {
            margin-top: 40px;
            display: flex;
            justify-content: center;
            gap: 20px;
            font-size: 14px;
            color: var(--azul-principal);
            flex-wrap: wrap;
        }
        
        /* ========== PROBLEMS ========== */
        .problems {
            background: var(--bege-escuro);
            border-radius: 30px;
            margin: 40px auto;
        }
        
        .problems__grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }
        
        .problem-card {
            background: var(--bege-claro);
            padding: 20px;
            border-radius: 15px;
            display: flex;
            gap: 15px;
            align-items: center;
            text-align: left;
        }
        
        .problem-icon {
            font-size: 24px;
        }
        
        /* ========== THE METHOD ========== */
        .method__grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            margin-top: 30px;
        }
        
        .day-card {
            background: var(--bege-escuro);
            padding: 20px;
            border-radius: 15px;
            border-left: 4px solid var(--dourado);
            text-align: left;
        }
        
        .day-card h4 {
            color: var(--azul-principal);
            margin-bottom: 10px;
        }
        
        /* ========== OFFER ========== */
        .offer {
            background: var(--azul-principal);
            color: var(--branco);
            border-radius: 30px;
            text-align: center;
            padding: 60px 20px;
        }
        
        .offer__title {
            font-size: 32px;
            margin-bottom: 20px;
            color: var(--branco);
        }
        
        .price-box {
            background: var(--bege-claro);
            color: var(--texto);
            padding: 30px;
            border-radius: 20px;
            display: inline-block;
            margin: 20px 0;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        
        .price-old {
            text-decoration: line-through;
            color: var(--texto-claro);
            font-size: 18px;
        }
        
        .price-new {
            font-size: 48px;
            font-weight: 700;
            color: var(--azul-principal);
            display: block;
            margin: 10px 0;
        }
        
        /* ========== FOOTER ========== */
        .footer {
            padding: 40px 0;
            text-align: center;
            font-size: 14px;
            color: var(--texto-claro);
        }
        
        @media (max-width: 768px) {
            .hero__title { font-size: 32px; }
            .btn { width: 100%; }
        }
    </style>
</head>
<body>

